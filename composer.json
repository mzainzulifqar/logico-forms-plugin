{
    "name": "logicoforms/laravel-forms",
    "description": "A Typeform-like forms system for Laravel with logic branching and AI builder.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Logicoforms\\Forms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Logicoforms\\Forms\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/ai": "^0.1.2"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Logicoforms\\Forms\\FormsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
